{
  "openai": {
    "api_key": "",
    "model": "gpt-3.5-turbo",
    "max_tokens": 2000,
    "temperature": 0.1,
    "timeout": 30,
    "max_retries": 3
  },
  "vllm_chat": {
    "base_url": "http://127.0.0.1:8000/v1",
    "model_name": "Qwen3-VL-8B-Instruct",
    "api_key": "EMPTY",
    "max_tokens": 2000,
    "temperature": 0.1,
    "timeout": 30
  },
  "vllm_embed": {
    "base_url": "http://127.0.0.1:8001/v1",
    "model_name": "Qwen3-VL-Embedding-2B",
    "api_key": "EMPTY",
    "timeout": 30
  },
  "detection": {
    "default_strategy": "local_yolo",
    "fallback_enabled": true,
    "auto_fallback": true,
    "max_concurrent": 5
  },
  "io": {
    "input_dir": "./inputs",
    "output_dir": "./outputs"
  },
  "agent": {
    "name": "HybridMonitoringAgent",
    "max_steps": 100,
    "verbose": true,
    "memory_size": 50,
    "enable_tools": true,
    "tools_enabled": [
      "detect_image",
      "safe_parse_json",
      "draw_bboxes",
      "process_video",
      "generate_report"
    ]
  },
  "rag": {
    "chunk_max_chars": 800,
    "chunk_overlap": 120,
    "dense_k": 3,
    "sparse_k": 5,
    "rrf_k": 60,
    "rerank_k": 10,
    "rerank_model": "cross-encoder/ms-marco-MiniLM-L-6-v2"
  },
  "debug": false,
  "log_level": "INFO",
  "cache_enabled": true,
  "cache_dir": "./cache"
}