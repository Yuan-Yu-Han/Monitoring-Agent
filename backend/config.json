{
  "openai": {
    "api_key": "",
    "model": "gpt-3.5-turbo",
    "max_tokens": 2000,
    "temperature": 0.1,
    "timeout": 30,
    "max_retries": 3
  },
  "vllm_chat": {
    "base_url": "http://127.0.0.1:8000/v1",
    "model_name": "Qwen3-VL-8B-Instruct",
    "api_key": "EMPTY",
    "max_tokens": 2000,
    "temperature": 0.1,
    "timeout": 30
  },
  "vllm_embed": {
    "base_url": "http://127.0.0.1:8001/v1",
    "model_name": "text-embedding-3-small",
    "api_key": "EMPTY",
    "timeout": 30
  },
  "monitoring": {
    "rtsp_url": "rtsp://127.0.0.1:8554/mystream",
    "rtsp_fps": 0.2,
    "rtsp_connect_timeout": 50,
    "yolo_model": "fire_yolo.pt",
    "yolo_confidence": 0.5,
    "yolo_device": "cuda:0",
    "use_vl_detection": false,
    "vl_detection_interval": 15,
    "suspect_threshold": 1,
    "alarm_threshold": 2,
    "idle_threshold": 10,
    "target_classes": [
      "Fire",
      "Smoke"
    ],
    "save_event_frames": true,
    "save_detection_frames": false,
    "output_dir": "./outputs/alarm",
    "detection_save_interval": 30,
    "max_event_images": 2000,
    "max_detection_images": 800,
    "max_agent_images": 2000,
    "max_vl_raw_files": 4000,
    "max_yolo_raw_files": 4000,
    "prune_interval_seconds": 60,
    "persist_yolo_detections": false,
    "persist_yolo_raw": false,
    "enable_signal_handling": true,
    "log_interval": 30
  },
  "io": {
    "input_dir": "./inputs",
    "output_dir": "./outputs"
  },
  "agent": {
    "name": "HybridMonitoringAgent",
    "max_steps": 100,
    "verbose": true,
    "memory_size": 50,
    "enable_tools": true,
    "enable_memory": false,
    "retrieval_targets": [],
    "expose_retrieval_debug": false,
    "tools_enabled": [
      "detect_image",
      "safe_parse_json",
      "draw_bboxes",
      "process_video",
      "generate_report"
    ]
  },
  "rag": {
    "chunk_max_chars": 400,
    "chunk_overlap": 80,
    "dense_k": 3,
    "sparse_k": 5,
    "rrf_k": 60,
    "rerank_k": 10,
    "rerank_model": "cross-encoder/ms-marco-MiniLM-L-6-v2",
    "enable_vector_memory": false,
    "embedding_backend": "vllm",
    "api_embed_base_url": "https://api.openai.com/v1",
    "api_embed_model": "text-embedding-3-small"
  },
  "debug": false,
  "log_level": "INFO",
  "cache_enabled": true,
  "cache_dir": "./cache"
}
